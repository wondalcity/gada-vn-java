# Hoist Expo/React Native packages to root node_modules so that Metro bundler,
# Babel, and Gradle can resolve them via standard Node module resolution.
# pnpm's strict isolation prevents transitive packages from being findable
# by tools that use their own resolution (Babel preset loading, Expo CLI, etc.)
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=@expo/*
public-hoist-pattern[]=@react-native/*
public-hoist-pattern[]=babel-preset-expo
public-hoist-pattern[]=react-refresh
public-hoist-pattern[]=@babel/runtime
public-hoist-pattern[]=@eslint/*
public-hoist-pattern[]=eslint*
