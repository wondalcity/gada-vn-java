{
  "$schema": "https://gada-vn.design/tokens/v1",
  "$description": "GADA VN Design Tokens — extracted from Figma file l9T36IlqSYGhGxAiRseRV7 (01. Style page). Material Design 3 token architecture.",

  "color": {
    "blue": {
      "$description": "Primary color. Represents the company/manager side. Used for trust/reliability.",
      "0":   { "$value": "#000000" },
      "10":  { "$value": "#072857" },
      "20":  { "$value": "#07397E" },
      "30":  { "$value": "#0454C5" },
      "40":  { "$value": "#0669F7", "$description": "Primary — main brand color" },
      "50":  { "$value": "#3186FF" },
      "60":  { "$value": "#539AFF" },
      "70":  { "$value": "#82B4FB" },
      "80":  { "$value": "#A3C8FF" },
      "90":  { "$value": "#C1DAFF" },
      "95":  { "$value": "#E3EFFF" },
      "99":  { "$value": "#F5F9FF" },
      "100": { "$value": "#FFFFFF" }
    },
    "yellow": {
      "$description": "Secondary color. Represents workers. Warm/friendly. DO NOT use as text color — poor contrast.",
      "0":   { "$value": "#000000" },
      "10":  { "$value": "#3C2C02" },
      "20":  { "$value": "#6F5102" },
      "30":  { "$value": "#DCA302" },
      "40":  { "$value": "#FDBC08" },
      "50":  { "$value": "#FFC72C" },
      "60":  { "$value": "#FFC72C" },
      "70":  { "$value": "#FFDB73" },
      "80":  { "$value": "#FFE490" },
      "90":  { "$value": "#FCECBB" },
      "95":  { "$value": "#FDF6E0" },
      "99":  { "$value": "#FEFBF1" },
      "100": { "$value": "#FFFFFF" }
    },
    "green": {
      "$description": "Tertiary / Success. Used for completion feedback. In attendance: pre-work-start stage.",
      "0":   { "$value": "#000000" },
      "10":  { "$value": "#024209" },
      "20":  { "$value": "#086908" },
      "30":  { "$value": "#079D07" },
      "40":  { "$value": "#00C800" },
      "50":  { "$value": "#5BD858" },
      "60":  { "$value": "#80DF7E" },
      "70":  { "$value": "#A1E9A0" },
      "80":  { "$value": "#B2EBB8" },
      "90":  { "$value": "#D1F3D3" },
      "95":  { "$value": "#E8F8E9" },
      "99":  { "$value": "#F3FDF3" },
      "100": { "$value": "#FFFFFF" }
    },
    "red": {
      "$description": "Error / warning. Badge color. In attendance: cancellation stage.",
      "0":   { "$value": "#000000" },
      "10":  { "$value": "#540C0E" },
      "20":  { "$value": "#861E21" },
      "30":  { "$value": "#AF2A2F" },
      "40":  { "$value": "#ED1C24" },
      "50":  { "$value": "#EE3B4F" },
      "60":  { "$value": "#F26272" },
      "70":  { "$value": "#FB9AA5" },
      "80":  { "$value": "#FFC4CB" },
      "90":  { "$value": "#FFDCE0" },
      "95":  { "$value": "#FFEFF1" },
      "99":  { "$value": "#FFF6F7" },
      "100": { "$value": "#FFFFFF" }
    },
    "orange": {
      "$description": "Event color. Used when events/promotions are active.",
      "0":   { "$value": "#000000" },
      "10":  { "$value": "#6E2712" },
      "20":  { "$value": "#AF3E1C" },
      "30":  { "$value": "#D33809" },
      "40":  { "$value": "#FF460D" },
      "50":  { "$value": "#FF7205" },
      "60":  { "$value": "#FF8B32" },
      "70":  { "$value": "#FFA762" },
      "80":  { "$value": "#FFC29E" },
      "90":  { "$value": "#FFDAC4" },
      "95":  { "$value": "#FFEADE" },
      "99":  { "$value": "#FFF8F3" },
      "100": { "$value": "#FFFFFF" }
    },
    "neutral": {
      "$description": "Used for surfaces and text. Disabled state uses N-70.",
      "0":   { "$value": "#000000" },
      "10":  { "$value": "#25282A" },
      "20":  { "$value": "#353535" },
      "30":  { "$value": "#474747" },
      "40":  { "$value": "#595959" },
      "50":  { "$value": "#7A7B7A" },
      "60":  { "$value": "#8E8E8E" },
      "70":  { "$value": "#B2B2B2", "$description": "Disabled state color" },
      "80":  { "$value": "#C4C4C4" },
      "90":  { "$value": "#DDDDDD" },
      "95":  { "$value": "#F2F2F2" },
      "99":  { "$value": "#F8F8FA" },
      "100": { "$value": "#FFFFFF" }
    },
    "neutralVariant": {
      "$description": "Primarily used for surface backgrounds.",
      "0":   { "$value": "#000000" },
      "10":  { "$value": "#161D25" },
      "20":  { "$value": "#233040" },
      "30":  { "$value": "#444F5D" },
      "40":  { "$value": "#657181" },
      "50":  { "$value": "#7E8A99" },
      "60":  { "$value": "#ADBAC8" },
      "70":  { "$value": "#C3CEDA" },
      "80":  { "$value": "#D6DCE5" },
      "90":  { "$value": "#DEE3EC" },
      "95":  { "$value": "#EEF1F6" },
      "99":  { "$value": "#F5F7FB" },
      "100": { "$value": "#FFFFFF" }
    },
    "layer": {
      "$description": "Transparent overlay layers. Used for floating, hover, press states.",
      "black80":  { "$value": "rgba(0,0,0,0.80)", "$description": "Scrim / modal backdrop" },
      "black30":  { "$value": "rgba(0,0,0,0.30)" },
      "black16":  { "$value": "rgba(0,0,0,0.16)" },
      "black8":   { "$value": "rgba(0,0,0,0.08)" },
      "white80":  { "$value": "rgba(255,255,255,0.80)" },
      "white30":  { "$value": "rgba(255,255,255,0.30)" },
      "white16":  { "$value": "rgba(255,255,255,0.16)" },
      "white8":   { "$value": "rgba(255,255,255,0.08)" },
      "primary80": { "$value": "rgba(6,105,247,0.80)" },
      "primary30": { "$value": "rgba(6,105,247,0.30)" },
      "primary16": { "$value": "rgba(6,105,247,0.16)" },
      "primary8":  { "$value": "rgba(6,105,247,0.08)" }
    }
  },

  "theme": {
    "$description": "Material Design 3 semantic role tokens. Use these in components, not raw palette values.",
    "primary":                { "$value": "{color.blue.40}",           "$hex": "#0669F7" },
    "onPrimary":              { "$value": "{color.blue.100}",          "$hex": "#FFFFFF" },
    "primaryContainer":       { "$value": "{color.blue.90}",           "$hex": "#C1DAFF" },
    "onPrimaryContainer":     { "$value": "{color.blue.10}",           "$hex": "#072857" },

    "secondary":              { "$value": "{color.yellow.40}",         "$hex": "#FDBC08" },
    "onSecondary":            { "$value": "{color.yellow.10}",         "$hex": "#3C2C02" },
    "secondaryContainer":     { "$value": "{color.yellow.90}",         "$hex": "#FCECBB" },
    "onSecondaryContainer":   { "$value": "{color.yellow.10}",         "$hex": "#3C2C02" },

    "tertiary":               { "$value": "{color.green.40}",          "$hex": "#00C800" },
    "onTertiary":             { "$value": "{color.green.100}",         "$hex": "#FFFFFF" },
    "tertiaryContainer":      { "$value": "{color.green.90}",          "$hex": "#D1F3D3" },
    "onTertiaryContainer":    { "$value": "{color.green.10}",          "$hex": "#024209" },

    "error":                  { "$value": "{color.red.40}",            "$hex": "#ED1C24" },
    "onError":                { "$value": "{color.red.100}",           "$hex": "#FFFFFF" },
    "errorContainer":         { "$value": "{color.red.90}",            "$hex": "#FFDCE0" },
    "onErrorContainer":       { "$value": "{color.red.10}",            "$hex": "#540C0E" },

    "surfaceDim":             { "$value": "{color.neutral.99}",        "$hex": "#F8F8FA" },
    "surface":                { "$value": "{color.neutral.100}",       "$hex": "#FFFFFF" },
    "surfaceBright":          { "$value": "{color.neutral.100}",       "$hex": "#FFFFFF" },
    "surfaceContainerLowest": { "$value": "{color.neutral.100}",       "$hex": "#FFFFFF" },
    "surfaceContainerLow":    { "$value": "{color.neutral.99}",        "$hex": "#F8F8FA" },
    "surfaceContainer":       { "$value": "{color.neutral.95}",        "$hex": "#F2F2F2" },
    "surfaceContainerHigh":   { "$value": "{color.neutral.90}",        "$hex": "#DDDDDD" },
    "surfaceContainerHighest":{ "$value": "{color.neutral.80}",        "$hex": "#C4C4C4" },

    "onSurface":              { "$value": "{color.neutral.10}",        "$hex": "#25282A" },
    "onSurfaceVariant":       { "$value": "{color.neutral.50}",        "$hex": "#7A7B7A" },
    "outline":                { "$value": "{color.neutral.90}",        "$hex": "#DDDDDD" },
    "outlineVariant":         { "$value": "{color.neutral.99}",        "$hex": "#F8F8FA" },
    "shadow":                 { "$value": "{color.neutral.0}",         "$hex": "#000000" },

    "inverseContainer":       { "$value": "{color.layer.black80}",     "$hex": "rgba(0,0,0,0.80)" },
    "inversePrimary":         { "$value": "{color.blue.70}",           "$hex": "#82B4FB" },
    "scrim":                  { "$value": "{color.layer.black30}",     "$hex": "rgba(0,0,0,0.30)" }
  },

  "typography": {
    "$description": "Font: system font stack (Noto Sans KR for Korean, Noto Sans for Vietnamese/English). All sizes in px, line-height in px.",
    "headline": {
      "h1": {
        "medium": { "fontSize": 32, "lineHeight": 40, "fontWeight": 500 },
        "bold":   { "fontSize": 32, "lineHeight": 40, "fontWeight": 700 }
      },
      "h2": {
        "medium": { "fontSize": 28, "lineHeight": 35, "fontWeight": 500 },
        "bold":   { "fontSize": 28, "lineHeight": 35, "fontWeight": 700 }
      },
      "h3": {
        "medium":    { "fontSize": 24, "lineHeight": 30, "fontWeight": 500 },
        "bold":      { "fontSize": 24, "lineHeight": 30, "fontWeight": 700 },
        "underline": { "fontSize": 24, "lineHeight": 30, "fontWeight": 700, "textDecoration": "underline" }
      }
    },
    "title": {
      "t1": { "bold":   { "fontSize": 20, "lineHeight": 25, "fontWeight": 700 } },
      "t2": { "bold":   { "fontSize": 18, "lineHeight": 23, "fontWeight": 700 } },
      "t3": {
        "medium": { "fontSize": 16, "lineHeight": 20, "fontWeight": 500 },
        "bold":   { "fontSize": 16, "lineHeight": 20, "fontWeight": 700 }
      },
      "t4": {
        "medium": { "fontSize": 14, "lineHeight": 18, "fontWeight": 500 },
        "bold":   { "fontSize": 14, "lineHeight": 18, "fontWeight": 700 }
      }
    },
    "paragraph": {
      "p1": { "fontSize": 18, "lineHeight": 26, "fontWeight": 400, "$description": "Body text default (바디 텍스트 기본)" },
      "p2": { "fontSize": 16, "lineHeight": 24, "fontWeight": 400 },
      "p2underline": { "fontSize": 16, "lineHeight": 24, "fontWeight": 400, "textDecoration": "underline" },
      "p3": { "fontSize": 14, "lineHeight": 20, "fontWeight": 400, "$description": "Sub text (서브 텍스트)" },
      "p4": { "fontSize": 13, "lineHeight": 18, "fontWeight": 400, "$description": "Sub text (서브 텍스트)" },
      "p5": { "fontSize": 11, "lineHeight": 16, "fontWeight": 400, "$description": "Sub text smallest (서브 텍스트)" }
    },
    "button": {
      "b1": {
        "medium": { "fontSize": 20, "lineHeight": 20, "fontWeight": 500 },
        "bold":   { "fontSize": 20, "lineHeight": 20, "fontWeight": 700 }
      },
      "b2": {
        "medium": { "fontSize": 18, "lineHeight": 18, "fontWeight": 500 },
        "bold":   { "fontSize": 18, "lineHeight": 18, "fontWeight": 700 }
      },
      "b3": {
        "medium":    { "fontSize": 16, "lineHeight": 16, "fontWeight": 500 },
        "underline": { "fontSize": 16, "lineHeight": 16, "fontWeight": 400, "textDecoration": "underline" },
        "bold":      { "fontSize": 16, "lineHeight": 16, "fontWeight": 700 }
      },
      "b4": {
        "medium":    { "fontSize": 14, "lineHeight": 14, "fontWeight": 500 },
        "underline": { "fontSize": 14, "lineHeight": 14, "fontWeight": 400, "textDecoration": "underline" },
        "bold":      { "fontSize": 14, "lineHeight": 14, "fontWeight": 700 }
      },
      "b5": {
        "medium": { "fontSize": 12, "lineHeight": 12, "fontWeight": 500 },
        "bold":   { "fontSize": 12, "lineHeight": 12, "fontWeight": 700 }
      }
    }
  },

  "spacing": {
    "$description": "4px base grid. Use only these values for margins, paddings, and gaps.",
    "4":  { "$value": "4px" },
    "8":  { "$value": "8px" },
    "12": { "$value": "12px" },
    "16": { "$value": "16px" },
    "20": { "$value": "20px" },
    "24": { "$value": "24px" },
    "32": { "$value": "32px" },
    "40": { "$value": "40px" },
    "48": { "$value": "48px" },
    "56": { "$value": "56px" },
    "64": { "$value": "64px" }
  },

  "layout": {
    "marginDefault": { "$value": "24px", "$description": "Standard page margin" },
    "marginCompact":  { "$value": "16px", "$description": "Compact margin (mixed use)" },
    "gutter":         { "$value": "16px" },
    "minWidth":       { "$value": "320px" },
    "maxWidth":       { "$value": "480px" },
    "touchTarget":    { "$value": "44px", "$description": "Minimum touch target (recommended)" }
  },

  "radius": {
    "$description": "Only two radius values in use. 4px default, 24px for pill/chip/FAB.",
    "sm":   { "$value": "4px",  "$description": "Default — cards, inputs, buttons" },
    "full": { "$value": "24px", "$description": "Pill — chips, rounded buttons, FAB" }
  },

  "icon": {
    "size16": { "$value": "16px", "$description": "Inline icons within text/labels" },
    "size24": { "$value": "24px", "$description": "Standard action icons" },
    "size32": { "$value": "32px", "$description": "Large decorative icons" },
    "strokeSmall": { "$value": "1.5pt", "$description": "16px icon stroke weight" },
    "strokeLarge": { "$value": "2pt",   "$description": "24px icon stroke weight" }
  },

  "gradient": {
    "brand": {
      "$description": "GADA brand gradient — symbolizes co-existence of workers and companies.",
      "from": "#FFC72C",
      "via1": "#0669F7",
      "via2": "#2BA170",
      "to":   "#0A5ED6"
    }
  }
}
