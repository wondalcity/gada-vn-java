# Server
PORT=7001
SPRING_PROFILES_ACTIVE=default

# Database (PostgreSQL)
DATABASE_URL=jdbc:postgresql://localhost:5432/gada
DATABASE_USER=postgres
DATABASE_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Firebase
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
FIREBASE_PROJECT_ID=gada-vn
FIREBASE_WEB_API_KEY=

# Admin service key (x-admin-key header)
ADMIN_SERVICE_KEY=local-dev-admin-service-key-000000000000

# AWS S3
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=gada-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CDN_DOMAIN=

# OTP
# Leave empty to generate random 6-digit OTPs
# Set to a fixed value (e.g. 999999) for dev/test — always accepted
OTP_FIXED_CODE=
