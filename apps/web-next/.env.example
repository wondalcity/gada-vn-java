# ════════════════════════════════════════════════════════════════
# apps/web-next — Next.js web app environment variables
# Copy to apps/web-next/.env.local and fill in real values.
# NEXT_PUBLIC_* variables are baked into the JS bundle at build time.
# Restart `pnpm dev` after changing any variable.
# See docs/setup/env-reference.md for full descriptions.
# ════════════════════════════════════════════════════════════════

# ── API endpoint ─────────────────────────────────────────────────
# Client-side (browser): full URL including /v1 path segment
# Used in src/lib/api/client.ts and src/lib/api/public.ts and ~20 components
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/v1

# Server-side only (Server Components, API route handlers)
# NOT exposed to browser — intentionally without NEXT_PUBLIC_ prefix
INTERNAL_API_URL=http://localhost:3001/v1

# ── Firebase Web SDK ─────────────────────────────────────────────
# All 6 values come from a single place:
# Firebase Console → Project Settings → Your apps
# → click </> to add a Web app if none exists
# → SDK snippet → Config object
# Use your dev project (gada-vn-dev) locally
NEXT_PUBLIC_FIREBASE_API_KEY=REPLACE_WITH_FIREBASE_WEB_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=gada-vn-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=gada-vn-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=gada-vn-dev.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Google Maps ──────────────────────────────────────────────────
# Optional locally — map renders but shows billing prompt without a key
# Restrict this key to localhost:3000 in the GCP Console for local dev
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── CDN ──────────────────────────────────────────────────────────
# Image delivery domain. Point to localhost API in local dev
# (the API serves S3 presigned URLs locally)
NEXT_PUBLIC_CDN_DOMAIN=localhost:3001

# ── SEO ──────────────────────────────────────────────────────────
# Canonical base URL. Used in src/app/robots.ts and src/app/sitemap.ts
# Local: localhost is fine — robots.txt won't be indexed
# Staging: https://staging.gada.vn
# Production: https://gada.vn
NEXT_PUBLIC_SITE_URL=http://localhost:3000
