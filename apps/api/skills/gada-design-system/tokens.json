{
  "colors": {
    "primary": "#0669F7",
    "secondary": "#FFC72C",
    "success": "#00C800",
    "error": "#ED1C24",
    "neutral": {
      "100": "#000000",
      "0": "#FFFFFF"
    },
    "semantic": {
      "text": {
        "default": "#25282A",
        "subtle": "#7A7B7A",
        "placeholder": "#98A2B2",
        "inverse": "#FFFFFF",
        "link": "#0669F7",
        "error": "#ED1C24",
        "success": "#00C800"
      },
      "background": {
        "page": "#F2F4F5",
        "card": "#FFFFFF",
        "overlay": "rgba(0,0,0,0.4)",
        "primary": "#0669F7",
        "primarySubtle": "#E6F0FE",
        "success": "#E6F9E6",
        "error": "#FDE8EE",
        "warning": "#FFF8E6"
      },
      "border": {
        "default": "#EFF1F5",
        "medium": "#DDDDDD",
        "strong": "#25282A",
        "primary": "#0669F7",
        "error": "#ED1C24"
      },
      "interactive": {
        "primaryDefault": "#0669F7",
        "primaryHover": "#0557D4",
        "primaryPressed": "#0448B0",
        "primaryDisabled": "#A8C7FD",
        "secondaryDefault": "#FFC72C",
        "secondaryHover": "#F0B800",
        "secondaryPressed": "#D9A500",
        "destructive": "#ED1C24",
        "destructiveHover": "#C8151B"
      }
    }
  },

  "typography": {
    "fontFamily": {
      "primary": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans KR', 'Noto Sans', sans-serif",
      "mono": "'JetBrains Mono', 'SF Mono', monospace"
    },
    "scale": {
      "headline01": {
        "fontSize": 32,
        "lineHeight": 40,
        "fontWeight": ["700", "500"],
        "tailwind": "text-[32px] leading-[40px]"
      },
      "headline02": {
        "fontSize": 28,
        "lineHeight": 35,
        "fontWeight": ["700", "500"],
        "tailwind": "text-[28px] leading-[35px]"
      },
      "headline03": {
        "fontSize": 24,
        "lineHeight": 30,
        "fontWeight": ["700", "500"],
        "tailwind": "text-2xl leading-[30px]"
      },
      "title01": {
        "fontSize": 20,
        "lineHeight": 25,
        "fontWeight": ["700"],
        "tailwind": "text-xl leading-[25px] font-bold"
      },
      "title02": {
        "fontSize": 18,
        "lineHeight": 23,
        "fontWeight": ["700"],
        "tailwind": "text-lg leading-[23px] font-bold"
      },
      "title03": {
        "fontSize": 16,
        "lineHeight": 20,
        "fontWeight": ["700", "500"],
        "tailwind": "text-base leading-5"
      },
      "paragraph01": {
        "fontSize": 18,
        "lineHeight": 26,
        "fontWeight": ["400"],
        "tailwind": "text-lg leading-[26px] font-normal"
      },
      "paragraph02": {
        "fontSize": 16,
        "lineHeight": 24,
        "fontWeight": ["400"],
        "tailwind": "text-base leading-6 font-normal"
      },
      "button01": {
        "fontSize": 20,
        "lineHeight": 20,
        "fontWeight": ["700", "500"],
        "tailwind": "text-xl leading-5"
      }
    }
  },

  "radius": {
    "small": {
      "value": 4,
      "tailwind": "rounded"
    },
    "large": {
      "value": 24,
      "tailwind": "rounded-3xl"
    },
    "full": {
      "value": 9999,
      "tailwind": "rounded-full"
    }
  },

  "spacing": {
    "layout": {
      "margin": 24,
      "gutter": 16
    },
    "scale": {
      "1": { "value": 4,  "tailwind": "1"  },
      "2": { "value": 8,  "tailwind": "2"  },
      "3": { "value": 12, "tailwind": "3"  },
      "4": { "value": 16, "tailwind": "4"  },
      "5": { "value": 20, "tailwind": "5"  },
      "6": { "value": 24, "tailwind": "6"  },
      "8": { "value": 32, "tailwind": "8"  },
      "10": { "value": 40, "tailwind": "10" },
      "12": { "value": 48, "tailwind": "12" },
      "14": { "value": 56, "tailwind": "14" },
      "16": { "value": 64, "tailwind": "16" }
    }
  },

  "shadow": {
    "card": "0 2px 8px rgba(0,0,0,0.06)",
    "modal": "0 8px 24px rgba(0,0,0,0.12)",
    "appBar": "0 2px 8px rgba(0,0,0,0.06)",
    "tabBar": "0 -2px 16px rgba(0,0,0,0.06)"
  },

  "touch": {
    "minTargetPt": 44,
    "minTargetPx": 44,
    "tailwind": "min-h-[44px] min-w-[44px]"
  },

  "breakpoints": {
    "mobile": "< 768px",
    "tablet": "768px (md:)",
    "desktop": "1024px (lg:)",
    "wide": "1280px (xl:)",
    "maxContent": "1760px"
  },

  "animation": {
    "durationDefault": "150ms",
    "durationMax": "300ms",
    "easing": "ease-in-out"
  },

  "zIndex": {
    "base": 0,
    "card": 1,
    "dropdown": 10,
    "sticky": 20,
    "appBar": 50,
    "modal": 100,
    "snackbar": 200,
    "tooltip": 300
  }
}
