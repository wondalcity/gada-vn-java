{% extends "layout.twig" %}

{% block content %}
<div class="flex gap-2 mb-6">
    {% for status, label in { '': '전체', OPEN: '모집 중', FILLED: '마감', CANCELLED: '취소됨' } %}
    <a
        href="/jobs?status={{ status }}"
        class="px-4 py-2 rounded-lg text-sm font-medium transition-colors {{ current_status == status ? 'bg-orange-500 text-white' : 'bg-white text-gray-600 hover:bg-gray-50 border border-gray-200' }}"
    >
        {{ label }}
    </a>
    {% endfor %}
</div>

<div class="bg-white rounded-2xl shadow-sm overflow-hidden">
    {% if jobs is iterable and jobs|length > 0 %}
    <table class="w-full">
        <thead class="bg-gray-50">
            <tr>
                <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase">현장명</th>
                <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase">근무일</th>
                <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase">일 노임</th>
                <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase">모집인원</th>
                <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase">상태</th>
                <th class="px-6 py-3"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            {% for job in jobs %}
            <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-sm font-medium text-gray-900">{{ job.site_name ?? job.title }}</td>
                <td class="px-6 py-4 text-sm text-gray-600">{{ job.work_date ?? '' }}</td>
                <td class="px-6 py-4 text-sm text-orange-600 font-medium">₫{{ job.daily_wage|number_format }}</td>
                <td class="px-6 py-4 text-sm text-gray-500">{{ job.slots_filled }}/{{ job.slots_total }}명</td>
                <td class="px-6 py-4">
                    {% if job.status == 'OPEN' %}
                        <span class="px-2 py-1 text-xs rounded-full bg-green-100 text-green-700">모집 중</span>
                    {% elseif job.status == 'FILLED' %}
                        <span class="px-2 py-1 text-xs rounded-full bg-blue-100 text-blue-700">마감</span>
                    {% else %}
                        <span class="px-2 py-1 text-xs rounded-full bg-gray-100 text-gray-500">{{ job.status }}</span>
                    {% endif %}
                </td>
                <td class="px-6 py-4 text-right">
                    <a href="/jobs/{{ job.id }}" class="text-orange-500 hover:underline text-sm">상세 →</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% else %}
    <div class="py-16 text-center text-gray-400">
        <div class="text-4xl mb-3">🏗️</div>
        <p>일자리가 없습니다</p>
    </div>
    {% endif %}
</div>
{% endblock %}
