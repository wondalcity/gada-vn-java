<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page_title ?? 'GADA VN' }} — Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
        [x-cloak] { display: none !important; }
        .sidebar-link { @apply flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-colors; }
        .sidebar-link:hover { @apply bg-white/10; }
        .sidebar-link.active { @apply bg-white text-orange-600; }
    </style>
</head>
<body class="bg-gray-50 font-sans">
<div class="flex min-h-screen">

    <!-- Sidebar -->
    <aside class="w-64 bg-gray-900 text-white flex flex-col flex-shrink-0">
        <div class="h-16 flex items-center px-6 border-b border-white/10">
            <span class="text-xl font-bold text-orange-400">가다 VN</span>
            <span class="ml-2 text-xs text-gray-400">Admin</span>
        </div>

        <nav class="flex-1 p-4 space-y-1">
            <a href="/" class="sidebar-link {{ current_path == '/' or current_path == '/dashboard' ? 'active' : '' }}">
                📊 대시보드
            </a>
            <a href="/managers" class="sidebar-link {{ current_path starts with '/managers' ? 'active' : '' }}">
                👔 관리자 승인
            </a>
            <a href="/workers" class="sidebar-link {{ current_path starts with '/workers' ? 'active' : '' }}">
                👷 근로자 관리
            </a>
            <a href="/jobs" class="sidebar-link {{ current_path starts with '/jobs' ? 'active' : '' }}">
                🏗️ 일자리 관리
            </a>
        </nav>

        <div class="p-4 border-t border-white/10">
            <div class="flex items-center gap-3 mb-3">
                <div class="w-8 h-8 rounded-full bg-orange-500 flex items-center justify-center text-sm font-bold">
                    {{ admin_username[0]|upper }}
                </div>
                <span class="text-sm text-gray-300">{{ admin_username }}</span>
            </div>
            <a href="/logout" class="block text-center text-xs text-gray-400 hover:text-white transition-colors">
                로그아웃
            </a>
        </div>
    </aside>

    <!-- Main -->
    <main class="flex-1 overflow-auto">
        <header class="h-16 bg-white border-b border-gray-200 flex items-center px-8">
            <h1 class="text-lg font-semibold text-gray-900">{{ page_title }}</h1>
        </header>

        <div class="p-8">
            {% block content %}{% endblock %}
        </div>
    </main>

</div>
</body>
</html>
