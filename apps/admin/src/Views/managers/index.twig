{% extends "layout.twig" %}

{% block content %}
<!-- Tab filters -->
<div class="flex gap-2 mb-6">
    {% for status, label in { PENDING: '대기 중', APPROVED: '승인됨', REJECTED: '거부됨' } %}
    <a
        href="/managers?status={{ status }}"
        class="px-4 py-2 rounded-lg text-sm font-medium transition-colors {{ current_status == status ? 'bg-orange-500 text-white' : 'bg-white text-gray-600 hover:bg-gray-50 border border-gray-200' }}"
    >
        {{ label }}
    </a>
    {% endfor %}
</div>

{% if app.request.query.get('flash') == 'approved' %}
<div class="bg-green-50 border border-green-200 text-green-700 rounded-lg p-4 mb-6 text-sm">
    ✅ 관리자가 승인되었습니다.
</div>
{% endif %}

<div class="bg-white rounded-2xl shadow-sm overflow-hidden">
    {% if managers is iterable and managers|length > 0 %}
    <table class="w-full">
        <thead class="bg-gray-50">
            <tr>
                <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase">회사명</th>
                <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase">담당자</th>
                <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase">유형</th>
                <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase">상태</th>
                <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase">가입일</th>
                <th class="px-6 py-3"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            {% for manager in managers %}
            <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 text-sm font-medium text-gray-900">{{ manager.company_name ?? '-' }}</td>
                <td class="px-6 py-4 text-sm text-gray-600">{{ manager.representative_name }}</td>
                <td class="px-6 py-4">
                    <span class="px-2 py-1 text-xs rounded-full bg-gray-100 text-gray-600">
                        {{ manager.business_type == 'CORPORATE' ? '법인' : '개인' }}
                    </span>
                </td>
                <td class="px-6 py-4">
                    {% if manager.approval_status == 'PENDING' %}
                        <span class="px-2 py-1 text-xs rounded-full bg-yellow-100 text-yellow-700">대기 중</span>
                    {% elseif manager.approval_status == 'APPROVED' %}
                        <span class="px-2 py-1 text-xs rounded-full bg-green-100 text-green-700">승인됨</span>
                    {% else %}
                        <span class="px-2 py-1 text-xs rounded-full bg-red-100 text-red-700">거부됨</span>
                    {% endif %}
                </td>
                <td class="px-6 py-4 text-sm text-gray-500">{{ manager.created_at|date('Y.m.d') ?? '' }}</td>
                <td class="px-6 py-4 text-right">
                    <a href="/managers/{{ manager.id }}" class="text-orange-500 hover:underline text-sm">상세 →</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% else %}
    <div class="py-16 text-center text-gray-400">
        <div class="text-4xl mb-3">📭</div>
        <p>해당하는 관리자가 없습니다</p>
    </div>
    {% endif %}
</div>
{% endblock %}
