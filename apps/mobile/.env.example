EXPO_PUBLIC_API_URL=http://localhost:3001/v1

# ── Google Maps / Places API Keys ─────────────────────────────────────────────
# Three separate keys are recommended; or use one key with all APIs enabled.
#
# 1. Maps SDK for Android — embedded in AndroidManifest via app.config.js
#    Restrict this key: Android app restriction + your SHA-1 fingerprints
GOOGLE_MAPS_ANDROID_KEY=

# 2. Maps SDK for iOS — embedded in Info.plist via app.config.js
#    Restrict this key: iOS app restriction + bundle identifier
#    Leave blank to use Apple Maps instead of Google Maps on iOS.
GOOGLE_MAPS_IOS_KEY=

# 3. Places API (New) — used in JS for address autocomplete (sites/create screen)
#    This key IS bundled into the JS bundle; restrict by HTTP referer or leave unrestricted.
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# ── Firebase ──────────────────────────────────────────────────────────────────
EXPO_PUBLIC_FIREBASE_WEB_CLIENT_ID=
