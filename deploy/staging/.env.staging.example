# ════════════════════════════════════════════════════════════════════════════
# GADA VN Staging — Environment Variables
# ════════════════════════════════════════════════════════════════════════════
# This file is the single source of truth for all staging env vars.
# fetch-secrets.sh reads this template and generates .env.api, .env.admin,
# .env.web from AWS Secrets Manager values.
#
# ⚠️  Never commit real values — this file must stay as an example template.
# ════════════════════════════════════════════════════════════════════════════

# ── Deployment ───────────────────────────────────────────────────────────────
IMAGE_TAG=latest                     # Git SHA set by deploy.sh
EC2_PUBLIC_DNS=ec2-52-76-20-8.ap-southeast-1.compute.amazonaws.com

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Full JDBC URL. Fetch from: /gada/staging/database-url
DATABASE_URL=jdbc:postgresql://HOST:5432/gada_staging
DATABASE_USER=gada_app               # Fetch from: /gada/staging/database-user
DATABASE_PASSWORD=CHANGE_ME          # Fetch from: /gada/staging/database-password

# ── Redis ────────────────────────────────────────────────────────────────────
# Fetch from: /gada/staging/redis-url (full URL)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                      # Fetch from: /gada/staging/redis-password

# ── Firebase (server-side SDK) ───────────────────────────────────────────────
# Credentials JSON stored as base64 in: /gada/staging/firebase-credentials
# fetch-secrets.sh decodes it to: deploy/staging/secrets/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=/app/firebase-service-account.json
FIREBASE_PROJECT_ID=gada-vn          # Fetch from: /gada/staging/firebase-project-id
FIREBASE_WEB_API_KEY=CHANGE_ME       # Fetch from: /gada/staging/firebase-web-api-key

# ── Firebase (client-side Web SDK) — baked into Next.js bundle at build ──────
NEXT_PUBLIC_FIREBASE_API_KEY=CHANGE_ME
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=gada-vn.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=gada-vn
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=gada-vn.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000

# ── AWS ──────────────────────────────────────────────────────────────────────
# EC2 instance profile provides credentials — do NOT set access keys here.
# The API uses the instance IAM role for S3 + Secrets Manager access.
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=gada-vn-staging-uploads
CDN_DOMAIN=                          # Leave empty on staging (use direct S3 URLs)

# ── Anthropic API ────────────────────────────────────────────────────────────
# Fetch from: /gada/staging/anthropic-api-key
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ── Admin service key (shared secret between api and admin) ──────────────────
# Fetch from: /gada/staging/admin-service-key
ADMIN_SERVICE_KEY=CHANGE_ME_64_chars_minimum

# ── JWT / Auth ───────────────────────────────────────────────────────────────
# Fetch from: /gada/staging/jwt-secret
JWT_SECRET=CHANGE_ME_random_64_hex

# ── Next.js public URLs ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://ec2-52-76-20-8.ap-southeast-1.compute.amazonaws.com/v1
NEXT_PUBLIC_SITE_URL=http://ec2-52-76-20-8.ap-southeast-1.compute.amazonaws.com
NEXT_PUBLIC_CDN_DOMAIN=              # Leave empty on staging
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyBkvE9sl2ZueLpUkGsCP8p9Kq6qHKHSZ6Q

# ── Admin panel ───────────────────────────────────────────────────────────────
API_BASE_URL=http://api:7001/v1      # Internal Docker network URL

# ── Admin email (AWS SES — uses EC2 instance profile; no SMTP keys needed) ───
# Prerequisite: EC2 IAM role must have ses:SendEmail permission
#   and MAIL_FROM address/domain must be verified in AWS SES console.
# Set MAIL_ENABLED=true once SES is configured.
MAIL_ENABLED=true
MAIL_FROM=noreply@gada.vn
