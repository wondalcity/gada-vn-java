# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — never commit real values.

aws_region = "ap-southeast-1"
project    = "gada-vn"
environment = "staging"

# Networking
vpc_cidr           = "10.10.0.0/16"
public_subnet_cidr = "10.10.1.0/24"
availability_zone  = "ap-southeast-1a"

# EC2
instance_type       = "t3.small"
root_volume_size_gb = 20
key_name            = "gada-staging"   # Must be pre-created: aws ec2 create-key-pair --key-name gada-staging

# SSH access — restrict to your IP or office CIDR
allowed_ssh_cidrs = [
  "1.2.3.4/32",  # Replace with your actual IP: curl -4 ifconfig.me
]

# AMI override (leave empty to auto-detect latest AL2023)
# ami_id = "ami-0abcdef1234567890"

# S3
# s3_uploads_bucket = "gada-vn-staging-uploads"  # defaults to this if empty

# CloudWatch detailed monitoring (extra cost, leave false for staging)
enable_detailed_monitoring = false
